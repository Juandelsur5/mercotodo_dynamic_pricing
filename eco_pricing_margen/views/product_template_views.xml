<odoo>
    <record id="view_product_template_form_eco_pricing" model="ir.ui.view">
        <field name="name">product.template.form.eco.pricing</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='list_price']" position="before">
                <field name="x_cost_base"/>
            </xpath>

            <xpath expr="//field[@name='list_price']" position="after">
                <group string="Margen por Canal (Precio Final con IVA)">
                    <group>
                        <div class="o_form_label">T.A.T</div>
                        <field name="x_utility_pct_tat" groups="eco_pricing_margen.group_margen_precios"/>
                        <field name="x_final_price_tat" readonly="1"/>
                    </group>
                    <group>
                        <div class="o_form_label">P.O.S</div>
                        <field name="x_utility_pct_pos" groups="eco_pricing_margen.group_margen_precios"/>
                        <field name="x_final_price_pos" readonly="1"/>
                    </group>
                    <group>
                        <div class="o_form_label">MAYORISTA</div>
                        <field name="x_utility_pct_mayorista" groups="eco_pricing_margen.group_margen_precios"/>
                        <field name="x_final_price_mayorista" readonly="1"/>
                    </group>
                    <group>
                        <div class="o_form_label">OFERTAS</div>
                        <field name="x_utility_pct_oferta" groups="eco_pricing_margen.group_margen_precios"/>
                        <field name="x_final_price_oferta" readonly="1"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
